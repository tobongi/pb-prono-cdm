# Express
PORT=3001

# CORS — URL of the Next.js frontend
WEB_URL=https://your-web-app.vercel.app

# Supabase — use the SERVICE ROLE key (not anon) so validation bypasses RLS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Admin endpoint protection — set a long random secret, pass as x-admin-key header
ADMIN_SECRET_KEY=change-me-to-a-long-random-secret
