# Port (Railway sets this automatically)
PORT=3001

# CORS — URL of the Next.js frontend
WEB_URL=https://your-web-app.vercel.app

# MongoDB (Railway MongoDB plugin)
MONGO_URL=mongodb://mongo:27017/worldcup2026

# worldcup2026 API (Railway service, internal URL)
WORLDCUP_API_URL=http://worldcup-api:5000

# Supabase — use the SERVICE ROLE key (not anon) so validation bypasses RLS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Admin endpoint protection — set a long random secret, pass as x-admin-key header
ADMIN_SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
